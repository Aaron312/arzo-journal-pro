{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ARZO Journal Pro",
  "version": "1.1.0",
  "identifier": "com.arzo.journal",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ARZO Journal Pro",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVEOENCNThDM0JEQzFFNkMKUldSc0h0dzdqTFdNWFVEaGRCQWVGbjhaZUsrdU5FaW13cjNiWFVTZWowalRmTXZQK0QyMEhEdGsK",
      "endpoints": [
        "https://github.com/Aaron312/arzo-journal-pro/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
